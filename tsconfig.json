{
  "compilerOptions": {
    "moduleResolution": "node",
    "module": "commonjs",
    "target": "es2022",
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": { "*": ["*", "*.ts"] },
    "lib": ["es2022", "dom"],
    "types": ["node", "mocha"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true
  },
  "ts-node": {
    "esm": false,
    "experimentalSpecifierResolution": "node",
    "transpileOnly": true
  },
  "include": ["tests", "pages", "util"]
}
